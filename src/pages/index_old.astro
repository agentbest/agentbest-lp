    .cta-body { color: #C7CCD4; margin-top: 1.7rem; max-width: 38em; margin-inline: auto; line-height: 2; }
    .cta-actions { margin-top: 2.8rem; }
    .cta-note { margin-top: 1.8rem; font-size: 0.74rem; color: var(--slate-mute); }

    /* ---------- COMPANY ---------- */
